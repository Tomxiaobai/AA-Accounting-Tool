/* ===== 全局样式 - Apple HIG 风格 ===== */
page {
  background-color: #f2f2f7;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', 'Helvetica Neue', Arial, sans-serif;
  color: #1c1c1e;
  font-size: 28rpx;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

view, text, button, input, picker, scroll-view {
  box-sizing: border-box;
}

/* 通用卡片 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 1rpx 0 rgba(0, 0, 0, 0.04),
              0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

/* 主色调 - iOS 薄荷绿 */
.text-primary {
  color: #34c759;
}

.bg-primary {
  background-color: #34c759;
}

.text-muted {
  color: #8e8e93;
}

.text-white {
  color: #ffffff;
}

/* 按钮 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-weight: 600;
  border: none;
  padding: 0;
  line-height: 1.5;
  letter-spacing: -0.2rpx;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #30d158 0%, #34c759 100%);
  color: #ffffff;
  height: 88rpx;
  font-size: 30rpx;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-primary[disabled] {
  background: #d1d1d6;
  color: rgba(255, 255, 255, 0.6);
  box-shadow: none;
}

.btn-outline {
  background-color: rgba(255, 255, 255, 0.9);
  color: #1c1c1e;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  height: 88rpx;
  font-size: 30rpx;
}

.btn-outline:active {
  background-color: rgba(0, 0, 0, 0.03);
}

.btn-ghost {
  background: transparent;
  color: #34c759;
  font-weight: 500;
}

.btn-ghost:active {
  opacity: 0.6;
}

/* 输入框 */
.input-field {
  background: #ffffff;
  border: 2rpx solid rgba(0, 0, 0, 0.08);
  border-radius: 16rpx;
  padding: 26rpx 16rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  color: #1c1c1e;
  transition: border-color 0.2s;
}

.input-field:focus,
.input-field-focus {
  border-color: #34c759;
  box-shadow: 0 0 0 4rpx rgba(52, 199, 89, 0.12);
}

/* 输入框居中 */
.input-field-center {
  text-align: center;
}

/* placeholder 居中 */
.placeholder-center {
  text-align: center;
}

/* 金额文字 */
.font-money {
  font-feature-settings: 'tnum';
  font-variant-numeric: tabular-nums;
  letter-spacing: -0.5rpx;
}

/* 加载动画 */
.loading-spinner {
  width: 44rpx;
  height: 44rpx;
  border: 4rpx solid rgba(0, 0, 0, 0.06);
  border-top-color: #34c759;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 140rpx 0;
}

.empty-icon {
  width: 128rpx;
  height: 128rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, rgba(52, 199, 89, 0.08) 0%, rgba(52, 199, 89, 0.15) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  font-size: 56rpx;
}

/* ===== 底部弹窗样式（键盘友好） ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 100;
}

.modal-dialog {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  z-index: 101;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.12);
}

.modal-handle {
  width: 64rpx;
  height: 8rpx;
  background: rgba(0, 0, 0, 0.1);
  border-radius: 4rpx;
  margin: 0 auto 28rpx;
}

.modal-header {
  margin-bottom: 32rpx;
  text-align: center;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
  letter-spacing: -0.5rpx;
}

.modal-desc {
  font-size: 26rpx;
  display: block;
  color: #8e8e93;
}

.modal-body {
  margin-bottom: 32rpx;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
}

.modal-btn {
  flex: 1;
  height: 84rpx;
  font-size: 30rpx;
  border-radius: 16rpx;
}
