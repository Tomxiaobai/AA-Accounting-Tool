/* 全局样式 */
page {
  background-color: #f5f5f7;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  color: #1d1d1f;
  font-size: 28rpx;
  line-height: 1.5;
}

/* 通用卡片 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-shadow {
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

/* 主色调 */
.text-primary {
  color: #10b981;
}

.bg-primary {
  background-color: #10b981;
}

.text-muted {
  color: #86868b;
}

.text-white {
  color: #ffffff;
}

/* 按钮 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  font-weight: 500;
  border: none;
  padding: 0;
  line-height: 1.5;
}

.btn::after {
  border: none;
}

.btn-primary {
  background-color: #10b981;
  color: #ffffff;
  height: 88rpx;
  font-size: 30rpx;
}

.btn-primary:active {
  background-color: #059669;
}

.btn-outline {
  background-color: #ffffff;
  color: #1d1d1f;
  border: 2rpx solid #e5e5ea;
  height: 88rpx;
  font-size: 30rpx;
}

.btn-outline:active {
  background-color: #f5f5f7;
}

.btn-ghost {
  background: transparent;
  color: #10b981;
}

/* 输入框 */
.input-field {
  background: #f5f5f7;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 金额文字 */
.font-money {
  font-feature-settings: 'tnum';
  font-variant-numeric: tabular-nums;
}

/* 加载动画 */
.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e5e5ea;
  border-top-color: #10b981;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 32rpx;
  background: #f0fdf4;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  font-size: 56rpx;
}
