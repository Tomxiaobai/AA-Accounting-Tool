.page {
  padding: 24rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.overview-skeleton {
  margin-bottom: 28rpx;
}

.skeleton-tabs {
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.skeleton-tab {
  flex: 1;
  height: 58rpx;
}

/* ===== 总览卡片 ===== */
.overview-card {
  margin-bottom: 28rpx;
}

.overview-grid {
  display: flex;
  flex-wrap: wrap;
}

.overview-item {
  width: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.overview-value {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
  letter-spacing: -0.5rpx;
}

.overview-label {
  font-size: 24rpx;
}

/* ===== Tab 栏 - iOS 分段控件 ===== */
.tab-bar {
  display: flex;
  background: rgba(118, 118, 128, 0.12);
  border-radius: 18rpx;
  padding: 4rpx;
  margin-bottom: 24rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 16rpx;
  color: #8e8e93;
  transition: all 0.2s ease;
  min-height: 64rpx;
}

.tab-active {
  background: #ffffff;
  color: #1c1c1e;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.04),
              0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

/* ===== 统计列表 ===== */
.stat-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.stat-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
}

.stat-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.stat-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, rgba(35, 196, 170, 0.12) 0%, rgba(35, 196, 170, 0.2) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.member-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f5f7fb 0%, #e8edf5 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  flex-shrink: 0;
}

.stat-info {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.stat-name {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  letter-spacing: -0.2rpx;
}

/* 进度条 */
.progress-bar {
  height: 6rpx;
  background: rgba(28, 31, 36, 0.06);
  border-radius: 3rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #27d2b6, #23c4aa);
  border-radius: 3rpx;
  transition: width 0.3s ease;
}

.stat-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
}

.stat-amount {
  font-size: 30rpx;
  font-weight: 600;
}

.stat-percent {
  font-size: 24rpx;
}
