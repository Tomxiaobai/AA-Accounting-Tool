.page {
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

/* 总览卡片 */
.overview-card {
  margin-bottom: 32rpx;
}

.overview-grid {
  display: flex;
  flex-wrap: wrap;
}

.overview-item {
  width: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.overview-value {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.overview-label {
  font-size: 24rpx;
}

/* Tab */
.tab-bar {
  display: flex;
  background: #f5f5f7;
  border-radius: 20rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 16rpx;
  color: #86868b;
}

.tab-active {
  background: #ffffff;
  color: #1d1d1f;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

/* 统计列表 */
.stat-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.stat-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
}

.stat-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.stat-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: #f0fdf4;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.member-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f5f5f7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.stat-info {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.stat-name {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.progress-bar {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #10b981;
  border-radius: 4rpx;
  transition: width 0.3s;
}

.stat-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
}

.stat-amount {
  font-size: 32rpx;
  font-weight: 600;
}

.stat-percent {
  font-size: 24rpx;
}
