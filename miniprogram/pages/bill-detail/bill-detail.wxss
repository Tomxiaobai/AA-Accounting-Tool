.page {
  padding: 24rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.summary-skeleton {
  margin-bottom: 24rpx;
}

.skeleton-actions {
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.skeleton-btn {
  flex: 1;
  height: 84rpx;
}

.skeleton-tabs {
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.skeleton-tab {
  flex: 1;
  height: 58rpx;
}

/* ===== 账单概要卡片 ===== */
.summary-card {
  margin-bottom: 24rpx;
}

.summary-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.summary-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, rgba(35, 196, 170, 0.12) 0%, rgba(35, 196, 170, 0.2) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.summary-icon {
  font-size: 40rpx;
}

.summary-amount {
  text-align: right;
}

.summary-label {
  font-size: 24rpx;
  display: block;
  margin-bottom: 4rpx;
}

.summary-value {
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: -1rpx;
}

.summary-bottom {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #8e8e93;
}

.summary-meta-sep {
  margin: 0 4rpx;
  opacity: 0.5;
}

/* ===== 操作按钮 ===== */
.action-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.action-btn {
  flex: 1;
  height: 84rpx;
  font-size: 28rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(35, 196, 170, 0.18);
}

.func-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.func-btn {
  flex: 1;
  height: 60rpx;
  font-size: 24rpx;
  border-radius: 14rpx;
  padding: 0 4rpx;
}

/* 删除按钮 */
.delete-row {
  margin-bottom: 24rpx;
  text-align: center;
}

.delete-btn {
  color: #ff3b30;
  font-size: 26rpx;
}

/* ===== Tab 栏 ===== */
.tab-bar {
  display: flex;
  background: rgba(118, 118, 128, 0.12);
  border-radius: 18rpx;
  padding: 4rpx;
  margin-bottom: 24rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 16rpx;
  color: #8e8e93;
  transition: all 0.2s ease;
  min-height: 64rpx;
}

.tab-active {
  background: #ffffff;
  color: #1c1c1e;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.04),
              0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

/* ===== 记录列表 ===== */
.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-card {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx 36rpx;
}

/* 成员卡片不需要底部 hint 间距 */
.member-card {
  padding-bottom: 24rpx;
}

.record-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.record-icon-wrap {
  width: 60rpx;
  height: 60rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, rgba(35, 196, 170, 0.12) 0%, rgba(35, 196, 170, 0.2) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.record-icon {
  font-size: 28rpx;
}

.record-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.record-category {
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: -0.2rpx;
}

.record-note {
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-meta {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  margin-top: 4rpx;
}

.record-amount {
  font-size: 32rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.record-delete-hint {
  position: absolute;
  right: 28rpx;
  bottom: 10rpx;
  font-size: 18rpx;
  opacity: 0.4;
}

/* 成员头像 */
.member-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f5f7fb 0%, #e8edf5 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  flex-shrink: 0;
}

.member-share {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

/* ===== 结算弹窗（底部弹出） ===== */
.settlement-dialog {
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  padding: 0 0 env(safe-area-inset-bottom);
}

.settlement-dialog .modal-handle {
  margin-top: 20rpx;
}

.settlement-dialog .modal-header {
  padding: 0 40rpx 24rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.settlement-scroll {
  flex: 1;
  padding: 28rpx 40rpx;
  max-height: 55vh;
}

.settlement-overview {
  display: flex;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.overview-item {
  flex: 1;
  background: #e8f7f3;
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
  text-align: center;
}

.overview-label {
  font-size: 22rpx;
  display: block;
  margin-bottom: 8rpx;
}

.overview-value {
  font-size: 28rpx;
  font-weight: 600;
}

.settlement-section {
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 24rpx;
  font-weight: 500;
  display: block;
  margin-bottom: 16rpx;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.member-detail {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.member-detail:last-child {
  border-bottom: none;
}

.member-name {
  font-size: 28rpx;
  font-weight: 500;
}

.member-balance {
  text-align: right;
  display: flex;
  flex-direction: column;
}

.text-green {
  color: #23c4aa;
}

.text-red {
  color: #ff3b30;
}

.transfer-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #e8f7f3;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
}

.transfer-from, .transfer-to {
  font-size: 26rpx;
  font-weight: 500;
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.transfer-arrow {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.settlement-perfect {
  background: rgba(35, 196, 170, 0.12);
  border-radius: 16rpx;
  padding: 28rpx;
  text-align: center;
  color: #23c4aa;
  font-size: 28rpx;
}

.settlement-footer {
  padding: 24rpx 40rpx 20rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

/* ===== 导出 Canvas（离屏） ===== */
.export-canvas-wrap {
  position: fixed;
  left: -9999px;
  top: 0;
}

.export-canvas {
  width: 600px;
  height: 1200px;
}
