.page {
  padding: 24rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

/* 顶部区域 */
.header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 36rpx;
  padding-top: 8rpx;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 56rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
  line-height: 1.15;
}

.user-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
  background: rgba(35, 196, 170, 0.12);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.user-badge-icon {
  font-size: 22rpx;
}

.user-badge-name {
  font-size: 24rpx;
  color: #23c4aa;
  font-weight: 600;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
}

/* 新建按钮 */
.create-btn {
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  height: 68rpx;
  border-radius: 34rpx;
  font-size: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(35, 196, 170, 0.22);
}

.btn-icon {
  margin-right: 6rpx;
  font-size: 28rpx;
  font-weight: 300;
}

/* 加载 */
.skeleton-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.skeleton-footer {
  margin-top: 18rpx;
  justify-content: space-between;
}

/* 空状态 */
.empty-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #8e8e93;
  margin-bottom: 40rpx;
  max-width: 420rpx;
  text-align: center;
  line-height: 1.6;
}

.empty-btn {
  padding: 0 48rpx;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* ===== 搜索栏 ===== */
.search-bar {
  margin-bottom: 24rpx;
}

.search-wrap {
  display: flex;
  align-items: center;
  background: #ffffff;
  border: 2rpx solid rgba(28, 31, 36, 0.06);
  border-radius: 20rpx;
  padding: 16rpx 20rpx;
  gap: 12rpx;
}

.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1c1f24;
  min-height: 40rpx;
}

.search-placeholder {
  color: #c7c7cc;
}

.search-clear {
  font-size: 26rpx;
  color: #c7c7cc;
  padding: 8rpx;
  flex-shrink: 0;
}

/* ===== 工具栏 ===== */
.toolbar-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  padding: 0 4rpx;
}

.display-count-entry {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.display-count-value {
  font-size: 24rpx;
  color: #23c4aa;
  font-weight: 600;
}

.toolbar-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.toolbar-tap {
  font-size: 24rpx;
  color: #8d93a6;
  padding: 12rpx 16rpx;
  min-height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.toolbar-tap:active {
  opacity: 0.5;
}

.toolbar-link-active {
  color: #23c4aa;
}

/* ===== 批量操作栏 ===== */
.batch-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 16rpx;
  margin-bottom: 16rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(10px);
  border-radius: 16rpx;
  border: 2rpx solid rgba(28, 31, 36, 0.06);
}

.batch-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.batch-label {
  font-size: 24rpx;
  color: #1c1f24;
}

.batch-count {
  font-size: 20rpx;
  color: #fff;
  background: #23c4aa;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  border-radius: 16rpx;
  padding: 0 8rpx;
  font-weight: 600;
}

.batch-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.batch-action {
  font-size: 22rpx;
  font-weight: 500;
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  transition: opacity 0.15s ease;
}

.batch-action-hide {
  background: rgba(255, 149, 0, 0.1);
  color: #ff9500;
}

.batch-action-delete {
  background: rgba(255, 59, 48, 0.1);
  color: #ff3b30;
}

.batch-action-disabled {
  opacity: 0.35;
  pointer-events: none;
}

/* ===== 条数选择弹窗 ===== */
.count-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: center;
  padding: 16rpx 0;
}

.count-option {
  width: 120rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  background: #f5f5f7;
  transition: all 0.2s ease;
}

.count-option:active {
  transform: scale(0.95);
}

.count-option-active {
  background: rgba(35, 196, 170, 0.15);
  border: 2rpx solid #23c4aa;
}

.count-option-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #1c1f24;
}

.count-option-active .count-option-text {
  color: #23c4aa;
  font-weight: 600;
}

/* ===== 展开/收起 ===== */
.toggle-row {
  display: flex;
  justify-content: center;
  margin-top: 20rpx;
}

.toggle-btn {
  font-size: 26rpx;
  color: #8d93a6;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.toggle-arrow {
  font-size: 20rpx;
}

/* ===== 账单列表 ===== */
.bill-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* ===== 滑动卡片 ===== */
.swipe-wrapper {
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
}

.swipe-actions {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: stretch;
  z-index: 1;
}

.swipe-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80px;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}

.swipe-btn-hide {
  background: #ff9500;
}

.swipe-btn-delete {
  background: #ff3b30;
}

/* ===== 账单卡片 ===== */
.bill-card {
  padding: 28rpx 32rpx;
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 20rpx;
  /* transform 由 WXS 内联设置，此处不定义 transition */
}

.bill-card-hidden {
  opacity: 0.55;
}

.bill-card-content {
  flex: 1;
  min-width: 0;
}

.bill-card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.bill-info {
  display: flex;
  flex-direction: column;
}

.bill-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.bill-name {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
  letter-spacing: -0.3rpx;
}

.hidden-tag {
  font-size: 20rpx;
  color: #ff9500;
  background: rgba(255, 149, 0, 0.1);
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.bill-date {
  font-size: 24rpx;
}

.bill-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, rgba(35, 196, 170, 0.12) 0%, rgba(35, 196, 170, 0.2) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.bill-icon {
  font-size: 32rpx;
}

.bill-card-bottom {
  display: flex;
  align-items: center;
}

.bill-amount {
  display: flex;
  flex-direction: column;
}

.bill-amount-label {
  font-size: 22rpx;
  margin-bottom: 2rpx;
}

.bill-amount-value {
  font-size: 34rpx;
  font-weight: 700;
}

.bill-divider {
  width: 1rpx;
  height: 44rpx;
  background: rgba(28, 31, 36, 0.08);
  margin: 0 28rpx;
}

.bill-members {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
}

.member-icon {
  font-size: 26rpx;
}

/* ===== 复选框 ===== */
.checkbox-wrap {
  flex-shrink: 0;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #c7c7cc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  transition: all 0.15s ease;
}

.checkbox-checked {
  background: #23c4aa;
  border-color: #23c4aa;
}

.checkbox-sm {
  width: 32rpx;
  height: 32rpx;
  border-width: 2rpx;
  font-size: 20rpx;
}

/* ===== 登录弹窗 ===== */
.login-footer {
  flex-direction: column;
  gap: 12rpx;
}
