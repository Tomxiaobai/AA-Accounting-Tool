.page {
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: -0.5rpx;
}

.create-btn {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.25);
}

.btn-icon {
  margin-right: 8rpx;
  font-size: 32rpx;
}

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #86868b;
  margin-bottom: 40rpx;
  max-width: 400rpx;
  text-align: center;
}

.empty-btn {
  padding: 0 40rpx;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* 账单列表 */
.bill-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.bill-card {
  padding: 32rpx;
  transition: transform 0.2s;
}

.bill-card:active {
  transform: scale(0.98);
}

.bill-card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.bill-info {
  display: flex;
  flex-direction: column;
}

.bill-name {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.bill-date {
  font-size: 24rpx;
}

.bill-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: #f0fdf4;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bill-icon {
  font-size: 36rpx;
}

.bill-card-bottom {
  display: flex;
  align-items: center;
}

.bill-amount {
  display: flex;
  flex-direction: column;
}

.bill-amount-label {
  font-size: 22rpx;
  margin-bottom: 4rpx;
}

.bill-amount-value {
  font-size: 36rpx;
  font-weight: 600;
}

.bill-divider {
  width: 2rpx;
  height: 48rpx;
  background: #e5e5ea;
  margin: 0 28rpx;
}

.bill-members {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
}

.member-icon {
  font-size: 28rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.modal-dialog {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx;
  z-index: 101;
}

.modal-header {
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 38rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.modal-desc {
  font-size: 26rpx;
  display: block;
}

.modal-body {
  margin-bottom: 32rpx;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  font-size: 30rpx;
  border-radius: 20rpx;
}
