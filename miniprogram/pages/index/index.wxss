.page {
  padding: 24rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

/* 顶部区域 */
.header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 36rpx;
  padding-top: 8rpx;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 56rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
  line-height: 1.15;
}

.user-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
  background: rgba(35, 196, 170, 0.12);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.user-badge-icon {
  font-size: 22rpx;
}

.user-badge-name {
  font-size: 24rpx;
  color: #23c4aa;
  font-weight: 600;
}

/* 新建按钮 */
.create-btn {
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  height: 68rpx;
  border-radius: 34rpx;
  font-size: 28rpx;
  margin-top: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(35, 196, 170, 0.22);
}

.btn-icon {
  margin-right: 6rpx;
  font-size: 28rpx;
  font-weight: 300;
}

/* 加载 */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.skeleton-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.skeleton-footer {
  margin-top: 18rpx;
  justify-content: space-between;
}

/* 空状态 */
.empty-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #8e8e93;
  margin-bottom: 40rpx;
  max-width: 420rpx;
  text-align: center;
  line-height: 1.6;
}

.empty-btn {
  padding: 0 48rpx;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* ===== 账单列表 ===== */
.bill-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.bill-card {
  padding: 28rpx 32rpx;
  transition: transform 0.15s ease;
}

.bill-card:active {
  transform: scale(0.975);
}

.bill-card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.bill-info {
  display: flex;
  flex-direction: column;
}

.bill-name {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
  letter-spacing: -0.3rpx;
}

.bill-date {
  font-size: 24rpx;
}

.bill-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, rgba(35, 196, 170, 0.12) 0%, rgba(35, 196, 170, 0.2) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.bill-icon {
  font-size: 32rpx;
}

.bill-card-bottom {
  display: flex;
  align-items: center;
}

.bill-amount {
  display: flex;
  flex-direction: column;
}

.bill-amount-label {
  font-size: 22rpx;
  margin-bottom: 2rpx;
}

.bill-amount-value {
  font-size: 34rpx;
  font-weight: 700;
}

.bill-divider {
  width: 1rpx;
  height: 44rpx;
  background: rgba(28, 31, 36, 0.08);
  margin: 0 28rpx;
}

.bill-members {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
}

.member-icon {
  font-size: 26rpx;
}

.bill-hint {
  display: block;
  font-size: 20rpx;
  text-align: right;
  margin-top: 10rpx;
  opacity: 0.5;
}

/* ===== 登录弹窗 ===== */
.login-footer {
  flex-direction: column;
  gap: 12rpx;
}
