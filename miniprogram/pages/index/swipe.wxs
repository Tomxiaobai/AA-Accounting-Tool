var THRESHOLD = 40;
var ACTION_WIDTH = 160;
var startX = 0;
var startY = 0;
var moved = false;
var dirLocked = false;
var isHorizontal = false;
var prevInstance = null;

function touchstart(e, ins) {
  startX = e.touches[0].clientX;
  startY = e.touches[0].clientY;
  moved = false;
  dirLocked = false;
  isHorizontal = false;

  // 关闭上一个已展开的卡片
  if (prevInstance && prevInstance !== e.instance) {
    prevInstance.setStyle({
      transform: 'translateX(0)',
      transition: 'transform 0.2s ease'
    });
    prevInstance = null;
    ins.callMethod('onSwipeEnd', { id: '' });
  }
}

function touchmove(e, ins) {
  var dx = e.touches[0].clientX - startX;
  var dy = e.touches[0].clientY - startY;

  if (!dirLocked && (Math.abs(dx) > 8 || Math.abs(dy) > 8)) {
    dirLocked = true;
    isHorizontal = Math.abs(dx) >= Math.abs(dy);
  }

  // 未锁定方向 或 纵向滑动 → 不拦截，允许页面滚动
  if (!dirLocked || !isHorizontal) return true;

  moved = true;
  var offset = dx;
  if (offset > 0) offset = 0;
  if (offset < -ACTION_WIDTH) offset = -ACTION_WIDTH;

  e.instance.setStyle({
    transform: 'translateX(' + offset + 'px)',
    transition: 'none'
  });

  // return false 阻止页面滚动
  return false;
}

function touchend(e, ins) {
  if (!moved || !isHorizontal) return;

  var dx = e.changedTouches[0].clientX - startX;
  var opened = dx < -THRESHOLD;
  var id = e.instance.getDataset().id || '';

  e.instance.setStyle({
    transform: opened ? 'translateX(-' + ACTION_WIDTH + 'px)' : 'translateX(0)',
    transition: 'transform 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94)'
  });

  if (opened) {
    prevInstance = e.instance;
  } else {
    prevInstance = null;
  }

  ins.callMethod('onSwipeEnd', { id: opened ? id : '' });
}

module.exports = {
  touchstart: touchstart,
  touchmove: touchmove,
  touchend: touchend
};
