<wxs module="util">
function formatAmount(amount) {
  return '¥' + Number(amount || 0).toFixed(2);
}
function formatDate(dateStr) {
  if (!dateStr) return '';
  var d = getDate(dateStr);
  if (isNaN(d.getTime())) return '';
  var m = d.getMonth() + 1;
  var day = d.getDate();
  return d.getFullYear() + '/' + (m < 10 ? '0' + m : m) + '/' + (day < 10 ? '0' + day : day);
}
module.exports = { formatAmount: formatAmount, formatDate: formatDate };
</wxs>

<!-- 账单列表页 -->
<view class="page">
  <!-- 顶部操作区 -->
  <view class="header">
    <view class="header-left">
      <text class="title">我的账单</text>
      <view class="user-badge" wx:if="{{isLoggedIn}}" bindtap="handleLogout">
        <text class="user-badge-icon">👤</text>
        <text class="user-badge-name">{{userName}}</text>
      </view>
    </view>
    <button class="btn btn-primary create-btn" bindtap="showCreateDialog" wx:if="{{isLoggedIn}}">
      <text class="btn-icon">+</text>
      <text>新建账单</text>
    </button>
  </view>

  <!-- 加载骨架 -->
  <block wx:if="{{loading}}">
    <view class="skeleton-list">
      <view class="card skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this">
        <view class="skeleton-row">
          <view class="skeleton skeleton-circle"></view>
          <view class="skeleton-col">
            <view class="skeleton skeleton-line skeleton-line-lg"></view>
            <view class="skeleton skeleton-line skeleton-line-sm skeleton-line-medium"></view>
          </view>
          <view class="skeleton skeleton-chip"></view>
        </view>
        <view class="skeleton-row skeleton-footer">
          <view class="skeleton skeleton-line skeleton-line-md skeleton-line-medium"></view>
          <view class="skeleton skeleton-line skeleton-line-md skeleton-line-short"></view>
        </view>
      </view>
    </view>
  </block>

  <!-- 未登录状态 -->
  <view class="empty-state" wx:elif="{{!isLoggedIn}}" bindtap="openLoginDialog">
    <view class="empty-icon">👤</view>
    <text class="empty-title">请先设置身份</text>
    <text class="empty-desc">设置你的昵称后开始记账</text>
    <button class="btn btn-primary empty-btn" bindtap="openLoginDialog">
      设置身份
    </button>
  </view>

  <!-- 已登录且有账单：搜索栏 + 列表/无结果 -->
  <block wx:elif="{{isLoggedIn && allBills.length > 0}}">
    <!-- 搜索栏 -->
    <view class="search-bar">
      <view class="search-wrap">
        <text class="search-icon">🔍</text>
        <input
          class="search-input"
          placeholder="搜索账单名称"
          placeholder-class="search-placeholder"
          value="{{searchKey}}"
          bindinput="onSearchInput"
        />
        <text class="search-clear" wx:if="{{searchKey}}" bindtap="clearSearch">✕</text>
      </view>
      <view class="display-count-entry" bindtap="showDisplayCountPicker">
        <text class="text-muted">默认展示</text>
        <text class="display-count-value">{{displayCount}}条</text>
      </view>
    </view>

    <!-- 搜索无结果 -->
    <view class="empty-state" wx:if="{{displayBills.length === 0}}">
      <view class="empty-icon">🔍</view>
      <text class="empty-title">未找到匹配账单</text>
      <text class="empty-desc">试试其他关键词</text>
    </view>

    <!-- 账单列表 -->
    <block wx:else>
    <view class="bill-list">
      <view
        class="card bill-card"
        wx:for="{{displayBills}}"
        wx:key="id"
        bindtap="goToBillDetail"
        bindlongpress="handleDeleteBill"
        data-id="{{item.id}}"
        data-name="{{item.name}}"
        data-creator="{{item.creator}}"
      >
        <view class="bill-card-top">
          <view class="bill-info">
            <text class="bill-name">{{item.name}}</text>
            <text class="bill-date text-muted">{{util.formatDate(item.createdAt)}}</text>
          </view>
          <view class="bill-icon-wrap">
            <text class="bill-icon">🧾</text>
          </view>
        </view>
        <view class="bill-card-bottom">
          <view class="bill-amount">
            <text class="bill-amount-label text-muted">总金额</text>
            <text class="bill-amount-value font-money">{{util.formatAmount(item.totalAmount)}}</text>
          </view>
          <view class="bill-divider"></view>
          <view class="bill-members">
            <text class="member-icon">👥</text>
            <text class="text-muted">{{item.memberCount || 0}} 人参与</text>
          </view>
        </view>
        <text class="bill-hint text-muted" wx:if="{{item.creator === userId}}">长按可删除</text>
      </view>
    </view>

    <!-- 展开/收起 -->
    <view class="toggle-row" wx:if="{{hasMore}}">
      <button class="btn btn-ghost toggle-btn" bindtap="toggleShowAll">
        {{showAll ? '收起' : '展开全部 (' + filteredCount + ')'}}
        <text class="toggle-arrow">{{showAll ? '▲' : '▼'}}</text>
      </button>
    </view>
  </block>
  </block>

  <!-- 空状态（已登录但无账单） -->
  <view class="empty-state" wx:elif="{{isLoggedIn && allBills.length === 0}}">
    <view class="empty-icon">🧾</view>
    <text class="empty-title">暂无账单</text>
    <text class="empty-desc">创建一个新的AA账单，开始记录多人消费吧</text>
    <button class="btn btn-primary empty-btn" bindtap="showCreateDialog">
      创建首个账单
    </button>
  </view>
</view>

<!-- 登录弹窗（底部弹出） -->
<view class="modal-mask" wx:if="{{showLoginDialog}}"></view>
<view class="modal-dialog" wx:if="{{showLoginDialog}}">
  <view class="modal-handle"></view>
  <view class="modal-header">
    <text class="modal-title">欢迎使用 AA记账</text>
    <text class="modal-desc text-muted">设置你的昵称，方便其他成员识别</text>
  </view>
  <view class="modal-body">
    <!-- type="nickname" 调起微信昵称选择器，选中后通过 bindblur 回写 -->
    <input
      class="input-field input-field-center modal-input"
      type="nickname"
      placeholder="输入或选择微信昵称"
      placeholder-class="placeholder-center"
      value="{{loginName}}"
      bindinput="onLoginNameInput"
      bindblur="onLoginNameBlur"
      bindconfirm="handleLogin"
      adjust-position="{{true}}"
    />
  </view>
  <view class="modal-footer">
    <button
      class="btn btn-primary modal-btn"
      bindtap="handleLogin"
      disabled="{{loginName.length === 0}}"
    >
      确认
    </button>
  </view>
</view>

<!-- 展示条数选择弹窗 -->
<view class="modal-mask" wx:if="{{showDisplayCountPicker}}" bindtap="hideDisplayCountPicker"></view>
<view class="modal-dialog" wx:if="{{showDisplayCountPicker}}">
  <view class="modal-handle"></view>
  <view class="modal-header">
    <text class="modal-title">默认展示条数</text>
    <text class="modal-desc text-muted">设置首页默认展示的账单数量</text>
  </view>
  <view class="modal-body">
    <view class="count-options">
      <view
        class="count-option {{displayCount === item ? 'count-option-active' : ''}}"
        wx:for="{{displayCountOptions}}"
        wx:key="*this"
        bindtap="selectDisplayCount"
        data-count="{{item}}"
      >
        <text class="count-option-text">{{item}}条</text>
      </view>
    </view>
  </view>
</view>

<!-- 创建账单弹窗 -->
<view class="modal-mask" wx:if="{{showCreateDialog}}" bindtap="hideCreateDialog"></view>
<view class="modal-dialog" wx:if="{{showCreateDialog}}">
  <view class="modal-handle"></view>
  <view class="modal-header">
    <text class="modal-title">创建账单</text>
    <text class="modal-desc text-muted">输入账单名称开始AA记账</text>
  </view>
  <view class="modal-body">
    <input
      class="input-field input-field-center modal-input"
      placeholder="例如：周末聚餐"
      placeholder-class="placeholder-center"
      value="{{newBillName}}"
      bindinput="onBillNameInput"
      bindconfirm="handleCreateBill"
      adjust-position="{{true}}"
    />
  </view>
  <view class="modal-footer">
    <button class="btn btn-outline modal-btn" bindtap="hideCreateDialog">取消</button>
    <button
      class="btn btn-primary modal-btn"
      bindtap="handleCreateBill"
      disabled="{{creating || newBillName.length === 0}}"
    >
      {{creating ? '创建中...' : '创建'}}
    </button>
  </view>
</view>
