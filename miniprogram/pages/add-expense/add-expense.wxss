.page {
  padding: 0 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  overflow: hidden;
}

/* ===== 金额输入区域 ===== */
.amount-section {
  padding: 40rpx 0 32rpx;
  text-align: center;
}

.amount-label {
  font-size: 26rpx;
  color: #8e8e93;
  display: block;
  margin-bottom: 20rpx;
}

.amount-input-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  justify-content: flex-start;
  padding: 22rpx 28rpx;
  background: #ffffff;
  border-radius: 28rpx;
  border: 1rpx solid rgba(28, 31, 36, 0.05);
  box-shadow: 0 12rpx 30rpx rgba(13, 41, 30, 0.05);
  max-width: 760rpx;
  margin: 0 auto;
}

.amount-prefix {
  font-size: 48rpx;
  font-weight: 700;
  color: #23c4aa;
  flex-shrink: 0;
  padding-top: 6rpx;
}

.amount-input {
  flex: 1;
  min-width: 0;
  width: 100%;
  font-size: 64rpx;
  font-weight: 700;
  color: #1c1c1e;
  text-align: left;
  line-height: 1.28;
  letter-spacing: -0.5rpx;
  padding: 12rpx 0;
  min-height: 96rpx;
  white-space: nowrap;
}

/* ===== 表单区域 ===== */
.section {
  margin-bottom: 32rpx;
}

.section-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #8e8e93;
  display: block;
  margin-bottom: 16rpx;
}

/* ===== 分类选择 ===== */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: calc((100% - 24rpx) / 3);
  height: 112rpx;
  background: #ffffff;
  border-radius: 16rpx;
  border: 2rpx solid rgba(28, 31, 36, 0.06);
  box-sizing: border-box;
  transition: all 0.15s ease;
}

.category-active {
  background: rgba(35, 196, 170, 0.12);
  border-color: #23c4aa;
}

.category-emoji {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.category-name {
  font-size: 22rpx;
  color: #1c1c1e;
  font-weight: 500;
}

/* ===== Picker 选择器 ===== */
.picker-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
  border: 2rpx solid rgba(28, 31, 36, 0.08);
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
  color: #1c1c1e;
  width: 100%;
}

.picker-arrow {
  font-size: 36rpx;
  color: #c7c7cc;
  font-weight: 300;
}

/* ===== 提交按钮 ===== */
.submit-btn {
  margin-top: 40rpx;
  height: 88rpx;
  font-size: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(35, 196, 170, 0.22);
}

.submit-btn[disabled] {
  background: #d1d1d6;
  box-shadow: none;
}
