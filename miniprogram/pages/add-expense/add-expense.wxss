.page {
  padding: 24rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.section {
  margin-bottom: 36rpx;
}

.section-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #8e8e93;
  display: block;
  margin-bottom: 16rpx;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

/* ===== 金额输入 ===== */
.amount-input-wrap {
  display: flex;
  align-items: center;
  background: #ffffff;
  border: 2rpx solid rgba(0, 0, 0, 0.08);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  transition: border-color 0.2s, box-shadow 0.2s;
}

.amount-input-wrap:focus-within {
  border-color: #34c759;
  box-shadow: 0 0 0 4rpx rgba(52, 199, 89, 0.12);
}

.amount-prefix {
  font-size: 44rpx;
  font-weight: 700;
  color: #34c759;
  margin-right: 12rpx;
}

.amount-input {
  flex: 1;
  font-size: 44rpx;
  font-weight: 600;
  color: #1c1c1e;
}

/* ===== 分类选择 ===== */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: calc(33.33% - 12rpx);
  height: 120rpx;
  background: #ffffff;
  border-radius: 20rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
}

.category-active {
  background: rgba(52, 199, 89, 0.06);
  border-color: #34c759;
  box-shadow: 0 0 0 4rpx rgba(52, 199, 89, 0.1);
}

.category-emoji {
  font-size: 36rpx;
  margin-bottom: 6rpx;
}

.category-name {
  font-size: 24rpx;
  color: #1c1c1e;
  font-weight: 500;
}

/* ===== Picker 选择器 ===== */
.picker-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
  border: 2rpx solid rgba(0, 0, 0, 0.08);
  border-radius: 16rpx;
  padding: 26rpx 24rpx;
  font-size: 30rpx;
  color: #1c1c1e;
}

.picker-arrow {
  font-size: 36rpx;
  color: #c7c7cc;
  font-weight: 300;
}

/* ===== 提交按钮 ===== */
.submit-btn {
  margin-top: 48rpx;
  height: 92rpx;
  font-size: 30rpx;
  border-radius: 22rpx;
  box-shadow: 0 4rpx 20rpx rgba(52, 199, 89, 0.3);
}

.submit-btn[disabled] {
  background: #d1d1d6;
  box-shadow: none;
}
