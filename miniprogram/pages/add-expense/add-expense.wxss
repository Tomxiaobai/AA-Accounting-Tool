.page {
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.section {
  margin-bottom: 40rpx;
}

.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1d1d1f;
  display: block;
  margin-bottom: 16rpx;
}

/* 金额输入 */
.amount-input-wrap {
  display: flex;
  align-items: center;
  background: #f5f5f7;
  border-radius: 20rpx;
  padding: 24rpx;
}

.amount-prefix {
  font-size: 44rpx;
  font-weight: 700;
  color: #10b981;
  margin-right: 12rpx;
}

.amount-input {
  flex: 1;
  font-size: 44rpx;
  font-weight: 600;
}

/* 分类 */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: calc(33.33% - 12rpx);
  height: 120rpx;
  background: #f5f5f7;
  border-radius: 20rpx;
  border: 3rpx solid transparent;
  transition: all 0.2s;
}

.category-active {
  background: #f0fdf4;
  border-color: #10b981;
}

.category-emoji {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.category-name {
  font-size: 24rpx;
  color: #1d1d1f;
}

/* Picker */
.picker-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f5f5f7;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
}

.picker-arrow {
  font-size: 36rpx;
  color: #86868b;
}

/* 提交按钮 */
.submit-btn {
  margin-top: 60rpx;
  height: 96rpx;
  font-size: 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.25);
}

.submit-btn[disabled] {
  background: #c3c3c3;
  box-shadow: none;
}
